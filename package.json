{
  "name": "local-libary-pp",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --inspect=0.0.0.0 -e ts -x tsx src/bin/www.ts",
    "lint": "eslint .",
    "prettier": "prettier -c **/*.{js,ts,css,json,pug,yaml,md}",
    "build": "tsc && mkdir -p dist/views/ && mkdir -p dist/public/ && cp -r views/* dist/views/ && cp -r public/* dist/public/",
    "start": "NODE_ENV=production node dist/bin/www.js"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "debug": "~4.3.4",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-async-handler": "^1.2.0",
    "express-favicon": "^2.0.4",
    "express-rate-limit": "^7.2.0",
    "express-robots-txt": "^1.0.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "http-errors": "~2.0.0",
    "http-status-codes": "^2.3.0",
    "luxon": "^3.4.4",
    "mongoose": "^8.2.1",
    "morgan": "^1.10.0",
    "pug": "^3.0.2"
  },
  "devDependencies": {
    "@prettier/plugin-pug": "^3.0.0",
    "@tsconfig/node20": "^20.1.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/debug": "^4.1.12",
    "@types/express": "^4.17.21",
    "@types/luxon": "^3.4.2",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.25",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-tsdoc": "^0.2.17",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2",
    "typescript-eslint": "^7.1.1"
  }
}
